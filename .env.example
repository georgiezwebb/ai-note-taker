# Copy to .env.local for local dev. On Vercel, add these in Project → Settings → Environment Variables.

# Neon Postgres (use the pooled connection string for serverless)
DATABASE_URL=

# Clerk — https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional: server-wide OpenAI key when users have not added their own
OPENAI_API_KEY=

# OpenAI model for polish / summarise (app default if unset: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Required when users save personal OpenAI keys (generate: openssl rand -base64 32)
OPENAI_KEY_ENCRYPTION_SECRET=
